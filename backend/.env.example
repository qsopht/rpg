NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Postgres — docker-compose maps the container port 5432 to host 5433
# (Windows-installed Postgres typically squats on 5432).
DATABASE_URL=postgres://aetheria:aetheria@localhost:5433/aetheria

# Redis — docker-compose maps the container port 6379 to host 6380.
REDIS_URL=redis://localhost:6380

# Auth
JWT_ACCESS_SECRET=change-me-32-bytes-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ARGON_MEMORY_KIB=65536
ARGON_ITERATIONS=3
ARGON_PARALLELISM=2

# Google Sign-In
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL where Google should redirect after consent (must match the
# Authorized redirect URI in the Google Cloud OAuth client).
# Local dev: http://localhost:3000 ; production: your Railway URL.
BACKEND_BASE_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:5173,capacitor://localhost

# Observability
SENTRY_DSN=
METRICS_ENABLED=true

# Content
CONTENT_DIR=../content
